# LLM Backend — Ollama (default)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=mistral-nemo

# LLM Backend — OpenAI (uncomment to switch)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o

# Internal services (defaults work with docker compose)
NOTIFIER_URL=http://notifier:8002/notify
SERVICE_REGISTRY_PATH=/app/service_registry.json
